APP_JWT_SECRET=replace_with_a_real_random_secret_that_is_at_least_32_bytes
APP_JWT_ACCESS_TOKEN_EXPIRATION_MS=86400000
APP_JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

